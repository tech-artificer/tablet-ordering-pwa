{
  "name": "wooserve",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npx nuxi dev --host 0.0.0.0",
    "test": "vitest",
    "typecheck": "npx nuxi typecheck",
    "build": "npx nuxi build",
    "generate": "npx nuxi build && npx nuxi generate && node -e \"const fs=require('fs'), path=require('path'); const src='.output/public', dst='public'; fs.existsSync(src) && fs.cpSync(src, dst, {recursive: true, force: true})\"",
    "preview": "npx nuxi preview --host 0.0.0.0",
    "rebuild:esbuild": "npm rebuild esbuild --update-binary || true",
    "postinstall": "nuxi prepare && npm run rebuild:esbuild",
    "clean": "rm -rf .nuxt .output node_modules package-lock.json"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@pinia/nuxt": "^0.11.2",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.5.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "element-plus": "^2.3.0",
    "laravel-echo": "^2.1.5",
    "lucide-vue-next": "^0.553.0",
    "nuxt": "^3.17.4",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.3.0",
    "pusher-js": "^8.4.0",
    "tailwind-merge": "^3.4.0",
    "vue": "^3.5.24",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@element-plus/nuxt": "^1.1.2",
    "@nuxt/devtools": "^2.4.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^1.13.0",
    "@nuxt/image": "^1.10.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^24.10.1",
    "@vite-pwa/nuxt": "^1.0.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.0.0-0",
    "dotenv": "^17.4.2",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^21.1.0",
    "playwright": "^1.40.1",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
