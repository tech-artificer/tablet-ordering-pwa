# ============================================
# Nuxt Frontend - Docker Build Exclusions
# ============================================
# Excludes files from Docker build context to:
# - Reduce build context size
# - Prevent host artifacts contaminating container
# - Speed up builds (especially important for ARM64 Pi builds)

# Git
.git
.gitignore
.gitattributes

# Dependencies (installed in container)
/node_modules
/.pnpm-store

# Build output (generated in container)
/.nuxt
/.output
/dist

# Environment files (injected at runtime)
.env
.env.*
!.env.example

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Testing
/tests
/test
*.test.ts
*.test.js
*.spec.ts
*.spec.js
/coverage
/.nyc_output

# Documentation
README.md
CHANGELOG.md
*.md

# Docker files (not needed in image)
Dockerfile
docker-compose*.yml
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.cache
.nuxt-cache
.nitro

# Misc
.eslintcache
.stylelintcache
