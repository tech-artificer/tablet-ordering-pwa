# Base Configuration
NUXT_APP_BASE_URL=/
APP_ENV=local
APP_VERSION=1.0

# API Configuration
MAIN_API_URL=https:/dist.test
CLIENT_BASE_URL=https:/woosoo-nexus.test

# Broadcasting Configuration
NUXT_PUBLIC_BROADCAST_CONNECTION=reverb

# Reverb Configuration
NUXT_PUBLIC_REVERB_APP_ID=
NUXT_PUBLIC_REVERB_APP_KEY=
NUXT_PUBLIC_REVERB_APP_SECRET=
NUXT_PUBLIC_REVERB_HOST=192.168.100.85
NUXT_PUBLIC_REVERB_PORT=8081
NUXT_PUBLIC_REVERB_SCHEME=http
NUXT_PUBLIC_REVERB_SERVER_HOST=0.0.0.0
NUXT_PUBLIC_REVERB_SERVER_PORT=8081
NUXT_PUBLIC_REVERB_SERVER_PATH=

# Laravel Echo Configuration (for frontend)
NUXT_PUBLIC_ECHO_HOST=192.168.100.85
NUXT_PUBLIC_ECHO_PORT=8081
NUXT_PUBLIC_ECHO_ENCRYPTED=false
