# ============================================
# Tablet Ordering PWA (Nuxt Frontend) - Docker Environment
# ============================================
# Copy this file to .env and configure with your values
# DO NOT commit .env to version control!

# ============================================
# Application
# ============================================
NODE_ENV=development
NUXT_PUBLIC_APP_NAME=Woosoo Tablet Ordering
NUXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# API Configuration
# ============================================
# Same-origin relative path is the canonical Docker/LAN setup.
# Override this only for direct local development outside the nginx gateway.
NUXT_PUBLIC_API_BASE_URL=/api

# ============================================
# WebSocket Configuration (Reverb)
# ============================================
# Same-origin HTTPS via nginx is the canonical Docker/LAN setup.
# Leave host empty to reuse the current browser hostname.
NUXT_PUBLIC_REVERB_APP_ID=woosoo
NUXT_PUBLIC_REVERB_APP_KEY=your_reverb_key_here
NUXT_PUBLIC_REVERB_HOST=
NUXT_PUBLIC_REVERB_PORT=443
NUXT_PUBLIC_REVERB_SCHEME=https
NUXT_PUBLIC_REVERB_PATH=/app

# ============================================
# Authentication
# ============================================
NUXT_PUBLIC_SANCTUM_ENDPOINT=/sanctum/csrf-cookie
NUXT_PUBLIC_SESSION_DOMAIN=

# ============================================
# PWA Configuration
# ============================================
NUXT_PUBLIC_PWA_ENABLED=true
NUXT_PUBLIC_PWA_CACHE_VERSION=v1

# ============================================
# Feature Flags
# ============================================
NUXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NUXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NUXT_PUBLIC_ENABLE_PRINTER_INTEGRATION=true

# ============================================
# Development Tools
# ============================================
# Opt in only when actively debugging Nuxt internals. Leaving this off keeps
# browser tooling focused on app assets instead of local filesystem source paths.
NUXT_DEVTOOLS=false
NUXT_PUBLIC_DEBUG=true

# ============================================
# Build Configuration
# ============================================
# The Dockerfile and CI set NITRO_PRESET=node-server at build time to produce
# .output/server/index.mjs for the Node.js container runtime.
# Local builds without NITRO_PRESET use Nitro's default preset.
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

# ============================================
# Logging
# ============================================
NUXT_PUBLIC_LOG_LEVEL=debug
