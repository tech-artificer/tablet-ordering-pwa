# ============================================
# Tablet Ordering PWA (Nuxt Frontend) - Docker Environment
# ============================================
# Copy this file to .env and configure with your values for standalone local dev.
# In the integrated Docker deployment, woosoo-nexus/compose.yaml injects the runtime values.
# DO NOT commit .env to version control!

# ============================================
# Application
# ============================================
NODE_ENV=development
NUXT_PUBLIC_APP_NAME=Woosoo Tablet Ordering
NUXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# API Configuration
# ============================================
# Integrated Docker/LAN deployment:
#   Tablet PWA: https://woosoo.local:4443
#   Backend API: https://woosoo.local/api
# Because the PWA is on port 4443 and the API is on 443, use the absolute API URL.
NUXT_PUBLIC_API_BASE_URL=https://woosoo.local/api

# For direct standalone local development outside the nginx gateway, override as needed:
# NUXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# ============================================
# WebSocket Configuration (Reverb)
# ============================================
NUXT_PUBLIC_BROADCAST_CONNECTION=reverb
NUXT_PUBLIC_REVERB_APP_ID=woosoo
NUXT_PUBLIC_REVERB_APP_KEY=your_reverb_key_here
NUXT_PUBLIC_REVERB_HOST=woosoo.local
NUXT_PUBLIC_REVERB_PORT=443
NUXT_PUBLIC_REVERB_SCHEME=https
NUXT_PUBLIC_REVERB_PATH=/app

# ============================================
# Authentication
# ============================================
NUXT_PUBLIC_SANCTUM_ENDPOINT=/sanctum/csrf-cookie
NUXT_PUBLIC_SESSION_DOMAIN=

# ============================================
# PWA Configuration
# ============================================
NUXT_PUBLIC_PWA_ENABLED=true
NUXT_PUBLIC_PWA_CACHE_VERSION=v1

# ============================================
# Feature Flags
# ============================================
NUXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NUXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NUXT_PUBLIC_ENABLE_PRINTER_INTEGRATION=true
NUXT_PUBLIC_OFFLINE_ORDER_SYNC=true

# ============================================
# Development Tools
# ============================================
# Opt in only when actively debugging Nuxt internals. Leaving this off keeps
# browser tooling focused on app assets instead of local filesystem source paths.
NUXT_DEVTOOLS=false
NUXT_PUBLIC_DEBUG=true

# ============================================
# Build Configuration
# ============================================
# The Dockerfile sets NITRO_PRESET=node-server at build time to produce
# .output/server/index.mjs for the Node.js container runtime.
# Local builds without NITRO_PRESET use Nitro's default preset.
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

# ============================================
# Logging
# ============================================
NUXT_PUBLIC_LOG_LEVEL=debug
